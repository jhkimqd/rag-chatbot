# Automatically activate the virtual environment when entering this directory.
# Requires direnv: https://direnv.net  (brew install direnv / apt install direnv)
# First-time setup: run `direnv allow` once after cloning.

if [ ! -d .venv ]; then
    echo "No .venv found — creating and installing dependencies..."
    python3 -m venv .venv
    .venv/bin/pip install -e ".[dev]" --quiet
fi

source .venv/bin/activate
