# LLM Backend: "anthropic" or "ollama"
# Use "ollama" for free local testing (no API key needed)
LLM_BACKEND=ollama

# Anthropic (only needed when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# Ollama (only needed when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CLASSIFIER_MODEL=llama3.2

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=polygon-docs

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Incident.io
INCIDENT_IO_API_KEY=

# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CHATBOT_API_KEY=
RATE_LIMIT_PER_MINUTE=30
DAILY_REQUEST_LIMIT=200
REQUEST_TIMEOUT_SECONDS=60
MAX_MESSAGE_LENGTH=2000
