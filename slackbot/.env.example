# LLM Backend: "anthropic" or "ollama"
LLM_BACKEND=ollama

# Anthropic (only needed when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=

# Ollama (only needed when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CLASSIFIER_MODEL=llama3.2

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Slack (required)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...

# Datadog (optional — enables metrics tools)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Incident.io (optional — enables incident tools)
INCIDENT_IO_API_KEY=

# Server
ENVIRONMENT=development
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=60
MAX_MESSAGE_LENGTH=2000
